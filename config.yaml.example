# Locale used for prompts, fallback copy, and the email template.
# Environment-variable expansion is supported here too.
locale: zh

email:
  # Final recipient list. Environment-variable expansion is supported.
  to:
    - ${EMAIL_TO}
  # Base subject line. Explicit config wins over locale defaults.
  subject: 新闻日报

schedule:
  # Cron expression used by the bundled cron-based Docker image.
  cron: "0 8 * * *"
  # Timezone used for filtering, timestamps, and rendered dates.
  timezone: Asia/Shanghai

ai:
  # Sampling temperature for all model calls.
  temperature: 0.3
  # Max completion tokens requested from the model.
  max_tokens: 16000
  # End-to-end timeout for a single AI HTTP request, in seconds.
  timeout: 180
  # Reference context window used only for local shard planning.
  context_window: 128000
  # Start sharding when estimated tokens exceed this ratio of context_window.
  shard_threshold_ratio: 0.6
  # Hard limit for the number of articles sent in one summarization shard.
  shard_max_articles: 35
  # Hard limit for the combined character count of one summarization shard.
  shard_max_chars: 120000
  # Structured output formats to try for summarization / categorization, in order.
  # Supported values: json_schema, json_object. Use [] to disable structured output.
  structured_output_summarization_formats: ["json_schema", "json_object"]
  # strict: fail immediately if all structured attempts fail.
  # prefer: try structured output first, then fall back to plain-text JSON.
  structured_output_summarization_policy: strict
  # Structured output formats to try for overview, in order.
  structured_output_overview_formats: ["json_schema", "json_object"]
  # Same policy semantics as summarization.
  structured_output_overview_policy: strict
  # Retries for transient transport / rate-limit / timeout failures.
  transient_retry_max: 8
  # Retries for invalid JSON or schema / business-rule validation failures.
  schema_retry_max: 8
  # Extra non-transient error keywords that should still be retried if they appear in the exception.
  retry_error_keywords: []
  # Switch to the next retry target after the current target fails this many times.
  retry_target_failure_threshold: 3
  # Retry targets used by summarization / categorization. Add more items to switch upstream/model on repeated failures.
  summarization_retry_targets:
    - name: primary
      base_url: ${OPENAI_BASE_URL}
      api_key: ${OPENAI_API_KEY}
      model: ${OPENAI_MODEL}
    # Optional backup target. Uncomment after setting OPENAI_BACKUP_* env vars.
    # - name: backup
    #   base_url: ${OPENAI_BACKUP_BASE_URL}
    #   api_key: ${OPENAI_BACKUP_API_KEY}
    #   model: ${OPENAI_BACKUP_MODEL}
  # Retry targets used by overview. You can keep them the same as summarization or tune separately.
  overview_retry_targets:
    - name: primary
      base_url: ${OPENAI_BASE_URL}
      api_key: ${OPENAI_API_KEY}
      model: ${OPENAI_MODEL}
    # Optional backup target. Uncomment after setting OPENAI_BACKUP_* env vars.
    # - name: backup
    #   base_url: ${OPENAI_BACKUP_BASE_URL}
    #   api_key: ${OPENAI_BACKUP_API_KEY}
    #   model: ${OPENAI_BACKUP_MODEL}
  # Base backoff schedule, in seconds, reused by retry logic.
  backoff_seconds: [1, 2, 4]
  # Extra random jitter added to retries, in milliseconds.
  jitter_ms_max: 300
  # Optional prompt hints. If empty, the pipeline first asks AI to suggest a compact category set for this batch.
  # If a configured category fits, the model should prefer these names.
  preferred_categories: []
  # If true, categorization must succeed after retries; otherwise continue with a flat article list.
  categorization_strict: true
  # If true, split overview generation (headline + groups) may retry with plain-text output when JSON output fails.
  overview_text_fallback: false
  # If true, overview may build a local rule-based overview when AI output fails.
  overview_local_fallback: false
  # If true, send a degraded raw-article email instead of failing the whole run.
  fallback_send_raw_email: false
  # Warning text shown in degraded emails.
  fallback_warning_text: "⚠ 本期 AI 摘要/分类生成失败，当前邮件为原文列表降级版。"
  # oneLine length controls. Weighted units treat CJK as 1 and ASCII as 0.5.
  one_line_hard_units: 42.0
  one_line_soft_units: 50.0
  one_line_trim_target_units: 48.0
  # Overview line length controls, counted in plain characters.
  summary_line_target_len: 120
  summary_line_hard_len: 140
  summary_line_soft_len: 168
  # Dump full model responses on failure.
  debug_dump_on_error: true
  # Dump every request/response pair. Prefer CLI flag --ai-debug for short-term debugging.
  debug_dump_all: false
  # Directory used for AI debug JSONL files.
  debug_dump_dir: logs/ai-debug
  # Rotate debug logs when the current file exceeds this size in bytes. <=0 disables rotation.
  debug_dump_max_bytes: 20971520
  # Delete debug logs older than this many days. <=0 disables age-based cleanup.
  debug_dump_retention_days: 14
  # Keep at most this many debug log files. <=0 disables count-based cleanup.
  debug_dump_max_files: 300

filter:
  # Only keep articles published within the most recent N hours.
  hours_back: 24
  # Truncate cleaned article bodies before they are sent to the model.
  max_content_length: 6000
  # If true, drop RSS items that do not expose a publish time.
  rss_missing_pub_date_strict: true

logging:
  # Standard Python logging level.
  level: INFO
  # Main application log file.
  file: logs/news-digest.log
  # Rotate the main log when it exceeds this size in bytes.
  max_bytes: 10485760
  # Number of rotated log files to keep.
  backup_count: 5
